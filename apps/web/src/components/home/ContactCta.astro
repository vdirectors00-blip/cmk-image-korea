---
import Button from "@/components/common/Button.astro";
import { sanityClient } from "@/lib/sanity";
import { siteSettingsQuery } from "@/lib/queries";
import type { SiteSettings } from "@/types/sanity";

const site = await sanityClient.fetch<SiteSettings | null>(siteSettingsQuery);

const phoneHref = site?.phone ? `tel:${site.phone.replace(/[^0-9+]/g, "")}` : null;
const emailHref = site?.email ? `mailto:${site.email}` : null;
---

<section class="bg-background">
  <div class="mx-[var(--divider-inset)] border-t border-foreground"></div>
  <div class="mx-auto max-w-[var(--container-max-wide)] px-[var(--container-padding)] py-16 md:py-32 text-center">
    <h2 class="font-serif text-[clamp(40px,6vw,80px)] leading-[1.1] tracking-[-0.02em] text-foreground">
      보이는 것을 함께 쌓는 일.
    </h2>
    <p class="mt-4 font-serif italic text-xl text-muted">
      What we build, together.
    </p>

    {/* 매거진 톤 본문 (v1.3.15) */}
    <p class="mx-auto mt-12 max-w-xl text-base leading-[1.75] text-soft">
      특강·그룹 코칭·1:1 진단까지, 모든 결을 함께 짭니다.
    </p>
    <p class="mx-auto mt-3 max-w-xl text-base leading-[1.75] text-soft">
      한 통의 연락이 한 사람의 인상을 새로 짓습니다.
    </p>

    {/* 3 버튼 동등 grid */}
    <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-3 sm:grid-cols-3">
      <Button variant="secondary" href="/contact?form=personal" class="w-full justify-center">
        개인 컨설팅 문의
      </Button>
      <Button variant="secondary" href="/contact?form=corporate" class="w-full justify-center">
        기업 출강 문의
      </Button>
      <Button variant="secondary" href="/contact?form=academy" class="w-full justify-center">
        Academy 수강 문의
      </Button>
    </div>

    {/* 회사 정보 — v1.3.15 D 옵션 */}
    {(phoneHref || emailHref) && (
      <div class="mt-16 flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-sm text-muted">
        {phoneHref && (
          <a href={phoneHref} class="transition-colors duration-200 hover:text-foreground">
            T. {site!.phone}
          </a>
        )}
        {emailHref && (
          <a href={emailHref} class="transition-colors duration-200 hover:text-foreground">
            E. {site!.email}
          </a>
        )}
      </div>
    )}
  </div>
</section>
