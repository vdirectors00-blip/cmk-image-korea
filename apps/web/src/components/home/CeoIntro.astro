---
import { urlFor } from "@/lib/image";
import type { Person } from "@/types/sanity";

interface Props {
  ceo: Person | null;
}

const { ceo } = Astro.props;

// CEO bio가 blockContent라 첫 문단만 단순 추출 (full body는 /about에서)
const firstParagraph = ceo?.bio?.ko
  ?.find((b) => b._type === "block" && b.children)
  ?.children?.map((c) => c.text ?? "")
  .join("");
---

<section class="bg-background">
  <div class="mx-[var(--divider-inset)] border-t border-foreground"></div>
  <div class="mx-auto grid max-w-[var(--container-max)] grid-cols-1 gap-12 px-[var(--container-padding)] py-32 md:grid-cols-12 md:gap-16">
    {/* 좌측 — CEO 인물 */}
    <div class="md:col-span-5">
      <div class="aspect-[3/4] overflow-hidden bg-panel">
        {ceo?.image ? (
          <img
            src={urlFor(ceo.image).width(600).height(800).fit("crop").url()}
            alt={ceo.name?.ko ?? ""}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        ) : (
          <img
            src="/images/ceo-fallback.jpg"
            alt="조미경 대표 — CMK 이미지코리아"
            class="h-full w-full object-cover"
            style="object-position: 50% 25%;"
            loading="lazy"
          />
        )}
      </div>
    </div>

    {/* 우측 — 짧은 소개 */}
    <div class="flex flex-col justify-center md:col-span-7">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">
        CEO
      </p>
      <h2 class="mt-4 font-serif text-[clamp(48px,6vw,80px)] leading-[1.05] tracking-[-0.02em] text-foreground">
        {ceo?.name?.ko ?? "조미경"}
      </h2>
      {ceo?.nameEn && (
        <p class="mt-2 font-serif italic text-2xl text-muted">{ceo.nameEn}</p>
      )}
      <p class="mt-8 max-w-xl text-base leading-[1.8] text-soft">
        {firstParagraph ??
          "이미지는 곧 언어다 — CMK는 30년간 한국 이미지컨설팅의 기준을 만들어 왔습니다."}
      </p>
      <a
        href="/about/ceo"
        class="mt-10 inline-block text-sm text-foreground underline-offset-4 hover:underline hover:text-accent"
      >
        자세히 보기 →
      </a>
    </div>
  </div>
</section>
