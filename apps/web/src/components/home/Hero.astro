---
import { urlFor } from "@/lib/image";
import type { SanityImage } from "@/types/sanity";

interface Props {
  image?: SanityImage;
}

const { image } = Astro.props;

// ⚠️ §13.3 #1 — 설립 연도 placeholder
const SINCE = "[YEAR]";
---

<section class="relative h-[calc(100svh-var(--header-height))] w-full overflow-hidden bg-dark">
  {/* v1.3.15 — Sanity image 있으면 우선, 없으면 fallback hero.jpg (사용자 제공). 그것도 없으면 다크 그라데이션. */}
  {image ? (
    <>
      <img
        src={urlFor(image).width(2400).height(1350).fit("crop").url()}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/40"></div>
    </>
  ) : (
    <>
      <img
        src="/images/hero/hero.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/30 to-black/55"></div>
    </>
  )}

  {/* 오버레이 카피 — 좌하단 매거진 톤 (text-on-dark 통일) */}
  <div class="relative z-10 mx-auto flex h-full max-w-[var(--container-max)] flex-col justify-end px-[var(--container-padding)] pb-24">
    <h1 class="font-serif italic text-[clamp(48px,8vw,128px)] leading-[1.0] tracking-[-0.02em] text-on-dark">
      What is seen is<br />
      what is communicated.
    </h1>
    <p class="mt-8 font-sans text-[clamp(20px,2.6vw,32px)] leading-[1.4] text-on-dark/90">
      보이는 것이, 전해지는 것입니다.
    </p>
    <p class="mt-10 text-[11px] font-semibold uppercase tracking-[0.18em] text-on-dark/70">
      CMK IMAGE KOREA &nbsp;·&nbsp; Since {SINCE}
    </p>
  </div>

  {/* Scroll indicator */}
  <div class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-center text-[10px] uppercase tracking-[0.2em] text-on-dark/70">
    <span class="block">Scroll</span>
    <span class="mt-1 inline-block h-4 w-px bg-on-dark/50"></span>
  </div>
</section>
