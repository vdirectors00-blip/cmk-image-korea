---
import { urlFor } from "@/lib/image";
import type { SanityImage } from "@/types/sanity";

interface Props {
  image?: SanityImage;
}

const { image } = Astro.props;
---

<section class="relative h-[calc(100svh-var(--header-height))] w-full overflow-hidden bg-dark">
  {image ? (
    <>
      <img
        src={urlFor(image).width(2400).height(1350).fit("crop").url()}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/40"></div>
    </>
  ) : (
    <>
      <img
        src="/images/hero/hero.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/15 via-black/20 to-black/40"></div>
    </>
  )}

  {/* 헤드라인 — 매거진 표지 톤: 가운데 상단, 굵은 산세리프 대문자, 두 줄 */}
  <div class="relative z-10 mx-auto flex h-full max-w-[var(--container-max-wide)] flex-col items-center justify-start px-[var(--container-padding)] pt-[clamp(16px,2.5vh,48px)] text-center">
    <h1 class="hero-headline font-display uppercase text-on-dark">
      CREATIVE PARTNER<br />
      CMK IMAGE KOREA
    </h1>
  </div>

  {/* Scroll indicator */}
  <div class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-center text-[10px] uppercase tracking-[0.2em] text-on-dark/70">
    <span class="block">Scroll</span>
    <span class="mt-1 inline-block h-4 w-px bg-on-dark/50"></span>
  </div>
</section>

<style>
  .hero-headline {
    font-weight: 400;
    font-size: clamp(40px, 10.5vw, 184px);
    line-height: 1.02;
    letter-spacing: 0.01em;
    word-spacing: 0.12em;
  }
  @media (min-width: 768px) {
    .hero-headline {
      word-spacing: 0.3em;
    }
  }
</style>
