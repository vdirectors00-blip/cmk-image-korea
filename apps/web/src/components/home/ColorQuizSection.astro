---
// §6.1 섹션 2 — HOME ColorQuiz embed (v1.3.15)
// 좌우 split + 컴팩트 (사용자 결정 A) — 좌 매거진 톤 카피 / 우 ColorQuiz React island.
import ColorQuiz from "@/components/quiz/ColorQuiz.tsx";
---

<section class="bg-background">
  <div class="mx-[var(--divider-inset)] border-t border-foreground"></div>
  <div class="mx-auto max-w-[var(--container-max)] px-[var(--container-padding)] py-20 md:py-24">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-16">

      {/* 좌 — 매거진 톤 카피 */}
      <div class="md:col-span-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">
          Personal Color
        </p>
        <h2 class="mt-4 font-serif text-[clamp(36px,4.5vw,56px)] leading-[1.1] tracking-[-0.02em] text-foreground">
          5초의 진단,<br />계절을 찾는 일.
        </h2>
        <p class="mt-6 max-w-md text-base leading-[1.7] text-soft">
          짧은 다섯 질문으로 본인의 컬러 시즌을 가늠합니다.
        </p>
        <p class="mt-3 max-w-md text-base leading-[1.7] text-soft">
          정식 진단은 1:1 컨설팅에서 — 결과 페이지에서 안내드립니다.
        </p>
      </div>

      {/* 우 — ColorQuiz React island */}
      <div class="md:col-span-7">
        <ColorQuiz client:visible />
      </div>

    </div>
  </div>
</section>
