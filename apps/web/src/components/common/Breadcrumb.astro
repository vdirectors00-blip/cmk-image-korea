---
// 서브 페이지 상단 작은 breadcrumb — 매거진 톤.
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav
  aria-label="Breadcrumb"
  class="border-b border-line bg-background"
>
  <div class="mx-[var(--divider-inset)] py-5">
    <ol class="flex flex-wrap items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">
      {items.map((item, i) => (
        <li class="flex items-center gap-2">
          {item.href ? (
            <a href={item.href} class="hover:text-accent transition-colors">
              {item.label}
            </a>
          ) : (
            <span class="text-foreground">{item.label}</span>
          )}
          {i < items.length - 1 && (
            <span class="text-faint">/</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
