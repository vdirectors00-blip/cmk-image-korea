---
// 매거진 카테고리 페이지 헤드 — VOGUE/MARIE 톤.
// 헤더 바로 아래에 위치. 가운데 정렬 큰 세리프 제목 + 부제 + 서브 카테고리 메뉴.
interface NavItem {
  label: string;
  href: string;
  active?: boolean;
}

interface Props {
  title: string;
  subtitle?: string;
  navItems?: NavItem[];
  /** §6.10 클라이언트 필터 — 지정 시 nav ul 에 `data-filter-nav` 부착 */
  filterKey?: string;
}

const { title, subtitle, navItems, filterKey } = Astro.props;
---

<section class="bg-background">
  <div class="page-head-wrap mx-auto max-w-[var(--container-max-wide)] px-[var(--container-padding)] text-center">
    {/* 큰 display 제목 — Staatliches condensed 매거진 표지 톤 */}
    <h1 class="page-head-title font-display uppercase leading-[0.95] tracking-[0.005em] text-foreground">
      {title}
    </h1>

    {subtitle && (
      <p class="mt-4 md:mt-6 text-sm text-muted">{subtitle}</p>
    )}

    {navItems && navItems.length > 0 && (
      <nav aria-label="Sub categories" class="mt-8 md:mt-12">
        <ul
          class="page-head-nav flex flex-wrap items-center justify-center"
          data-filter-nav={filterKey}
        >
          {navItems.map((item) => {
            const baseLink = "page-head-nav-link font-display uppercase tracking-[0.05em] transition-colors duration-200 ease-[var(--ease-out-soft)] text-muted hover:text-foreground";
            return (
              <li>
                <a
                  href={item.href}
                  class={`${baseLink} ${item.active ? "is-active" : ""}`}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    )}
  </div>
</section>

<style>
  .page-head-wrap {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  .page-head-title {
    font-size: clamp(36px, 6.5vw, 104px);
  }
  .page-head-nav {
    row-gap: 0.75rem;
    column-gap: 1.5rem;
  }
  .page-head-nav-link {
    font-size: clamp(15px, 1.9vw, 30px);
  }
  @media (min-width: 768px) {
    .page-head-wrap {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
    .page-head-title {
      font-size: clamp(40px, 6.5vw, 104px);
    }
    .page-head-nav {
      column-gap: 3rem;
    }
    .page-head-nav-link {
      font-size: clamp(18px, 1.9vw, 30px);
    }
  }
</style>
