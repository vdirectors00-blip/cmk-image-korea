---
// §6.2 섹션 3 — CEO 조미경 (full)
// ⚠️ §13.3 #3·#4·#5·#6 — 인사말/영문/AICI/저서 placeholder
import { urlFor } from "@/lib/image";
import { pickLocale } from "@/types/sanity";
import type { Person } from "@/types/sanity";

interface Props {
  ceo: Person | null;
}

const { ceo } = Astro.props;

// bio 전체 paragraph 추출 (HOME의 first paragraph 와 달리 전체 노출)
const paragraphs =
  ceo?.bio?.ko
    ?.filter((b) => b._type === "block" && b.children)
    .map((b) =>
      (b.children ?? [])
        .map((c) => c.text ?? "")
        .join("")
    )
    .filter(Boolean) ?? [];
---

<section class="bg-background">
  <div class="mx-auto max-w-[var(--container-max)] px-[var(--container-padding)] py-32">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-16">
      {/* 좌측 — 인물 사진 */}
      <div class="md:col-span-5">
        <div class="aspect-[3/4] overflow-hidden bg-cream">
          {ceo?.image ? (
            <img
              src={urlFor(ceo.image).width(720).height(960).fit("crop").url()}
              alt={pickLocale(ceo.name)}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          ) : (
            <img
              src="/images/ceo-fallback.jpg"
              alt="조미경 대표 — CMK 이미지코리아"
              class="h-full w-full object-cover"
              style="object-position: 50% 25%;"
              loading="lazy"
            />
          )}
        </div>
      </div>

      {/* 우측 — 프로필 */}
      <div class="md:col-span-7">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">
          CEO
        </p>
        <h2 class="mt-4 font-serif text-[clamp(48px,6vw,80px)] leading-[1.05] tracking-[-0.02em] text-foreground">
          {pickLocale(ceo?.name) || "조미경"}
        </h2>
        {ceo?.nameEn && (
          <p class="mt-2 font-serif italic text-2xl text-muted">
            {ceo.nameEn}
          </p>
        )}

        {/* 인사말 본문 */}
        <div class="mt-10 space-y-6 text-base leading-[1.8] text-soft">
          {paragraphs.length > 0 ? (
            paragraphs.map((p) => <p>{p}</p>)
          ) : (
            <>
              <p>
                CMK는 30년간 한국 이미지컨설팅의 기준을 만들어 왔습니다.
                한 사람의 인상이 회사의 인상이 되고, 회사의 인상이 한
                시대의 언어가 되는 과정에 함께해 왔습니다.
              </p>
              <p class="text-faint">
                [ Phase 3 placeholder · 인사말 원고 입수 후 교체 — §13.3 #3 ]
              </p>
            </>
          )}
        </div>

        {/* Credentials — v1.3.14 사용자 결정으로 임시 숨김. 클라이언트 정식 약력 입수 후 재노출 */}
      </div>
    </div>
  </div>
</section>
