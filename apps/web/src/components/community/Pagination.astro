---
// Community 페이지네이션 nav (v1.3.15)
// prev / next + page N of M + (optional) 번호 list.
interface Props {
  currentPage: number;
  totalPages: number;
  /** prev 페이지 URL (없으면 disable) */
  prevHref?: string;
  /** next 페이지 URL (없으면 disable) */
  nextHref?: string;
  /** 페이지 번호 → URL 변환기 (예: (n) => n === 1 ? "/community" : `/community/page/${n}`) */
  pageHref: (n: number) => string;
}

const { currentPage, totalPages, prevHref, nextHref, pageHref } = Astro.props;

// 페이지 번호 list — 1, current ±2, last. 너무 많으면 ellipsis.
function getPageList(current: number, total: number): Array<number | "ellipsis"> {
  if (total <= 7) return Array.from({length: total}, (_, i) => i + 1);
  const out: Array<number | "ellipsis"> = [1];
  if (current > 4) out.push("ellipsis");
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    out.push(i);
  }
  if (current < total - 3) out.push("ellipsis");
  out.push(total);
  return out;
}

const pageList = getPageList(currentPage, totalPages);
---

{totalPages > 1 && (
  <nav class="mt-24 border-t border-line pt-8" aria-label="Pagination">
    <div class="flex items-center justify-between gap-4">
      {/* Prev */}
      {prevHref ? (
        <a
          href={prevHref}
          class="text-xs uppercase tracking-[0.18em] text-foreground transition-colors hover:text-accent"
        >
          ← Previous
        </a>
      ) : (
        <span class="text-xs uppercase tracking-[0.18em] text-faint">← Previous</span>
      )}

      {/* 페이지 번호 list — md+ 에서만 */}
      <ul class="hidden items-center gap-2 md:flex">
        {pageList.map((p) =>
          p === "ellipsis" ? (
            <li class="px-2 text-xs text-faint">…</li>
          ) : (
            <li>
              <a
                href={pageHref(p)}
                class:list={[
                  "px-3 py-1 text-xs uppercase tracking-[0.18em] transition-colors",
                  p === currentPage
                    ? "border-b border-foreground text-foreground"
                    : "text-muted hover:text-foreground",
                ]}
                aria-current={p === currentPage ? "page" : undefined}
              >
                {String(p).padStart(2, "0")}
              </a>
            </li>
          )
        )}
      </ul>

      {/* 모바일 — page N of M */}
      <p class="text-xs uppercase tracking-[0.18em] text-muted md:hidden">
        Page {currentPage} of {totalPages}
      </p>

      {/* Next */}
      {nextHref ? (
        <a
          href={nextHref}
          class="text-xs uppercase tracking-[0.18em] text-foreground transition-colors hover:text-accent"
        >
          Next →
        </a>
      ) : (
        <span class="text-xs uppercase tracking-[0.18em] text-faint">Next →</span>
      )}
    </div>
  </nav>
)}
