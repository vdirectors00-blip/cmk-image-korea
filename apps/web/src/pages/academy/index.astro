---
// /academy — 인덱스 (PageHead + 4 강좌 카드, v1.3.15)
// 사용자 결정 — level 필터 폐기, 단순 4 강좌 grid. sub-nav 가 직접 페이지 이동.
import BaseLayout from "@/layouts/BaseLayout.astro";
import AcademyPageHead from "@/components/academy/AcademyPageHead.astro";
import CategoryCard from "@/components/common/CategoryCard.astro";
import ScrollToTop from "@/components/common/ScrollToTop.astro";

import { sanityClient } from "@/lib/sanity";
import { academyCoursesAllQuery } from "@/lib/queries";
import { pickLocale } from "@/types/sanity";
import type { AcademyCourse } from "@/types/sanity";

const courses = await sanityClient.fetch<AcademyCourse[]>(academyCoursesAllQuery);

// v1.3.16 — 사용자 제공 academy 카드 image (apps/web/public/images/academy/{slug}.png).
const ACADEMY_HERO: Record<string, string> = {
  "taste-image-scale": "/images/academy/taste-image-scale.png",
  "image-consultant": "/images/academy/image-consultant.png",
  "makeup": "/images/academy/makeup.png",
  "personal-color": "/images/academy/personal-color.png",
};
---

<BaseLayout
  title="Academy — CMK Image Korea"
  description="자격 과정 · 강사 양성 — Taste Image Scale · 이미지컨설턴트 전략 · 퍼스널컬러 진단 · 메이크업"
>
  <AcademyPageHead />

  <section class="bg-background">
    <div class="mx-auto max-w-[var(--container-max)] px-[var(--container-padding)] py-14 md:py-24">
      {courses.length === 0 ? (
        <div class="py-16 md:py-32 text-center">
          <p class="font-serif italic text-3xl text-faint">Coming Soon</p>
          <p class="mt-3 text-sm text-muted">강좌 정보가 곧 공개됩니다.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-2 md:gap-x-10 md:gap-y-20">
          {courses.map((course) => (
            <CategoryCard
              href={`/academy/${course.slug.current}`}
              eyebrow={course.level ?? ""}
              title={pickLocale(course.title)}
              description={pickLocale(course.summary)}
              fallbackSrc={ACADEMY_HERO[course.slug.current]}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <ScrollToTop />
</BaseLayout>
