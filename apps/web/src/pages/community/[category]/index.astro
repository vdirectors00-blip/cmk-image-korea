---
// /community/[category] — 카테고리별 1번 페이지 (v1.3.16).
// category = "media" | "news". media = "강의·미디어", news = "뉴스".
import BaseLayout from "@/layouts/BaseLayout.astro";
import CommunityPageHead from "@/components/community/CommunityPageHead.astro";
import PostCard from "@/components/community/PostCard.astro";
import Pagination from "@/components/community/Pagination.astro";
import ScrollToTop from "@/components/common/ScrollToTop.astro";

import { sanityClient } from "@/lib/sanity";
import { postsByCategoryQuery } from "@/lib/queries";
import type { Post, PostCategory } from "@/types/sanity";

const CATEGORY_MAP: Record<string, { sanity: PostCategory; label: string }> = {
  media: { sanity: "강의·미디어", label: "Media" },
  news: { sanity: "뉴스", label: "News" },
};

export async function getStaticPaths() {
  return [
    { params: { category: "media" } },
    { params: { category: "news" } },
  ];
}

const { category } = Astro.params;
const cat = CATEGORY_MAP[category as string];

if (!cat) {
  return Astro.redirect("/community");
}

const PAGE_SIZE = 12;
const allPosts = await sanityClient.fetch<Post[]>(postsByCategoryQuery, { category: cat.sanity });
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const posts = allPosts.slice(0, PAGE_SIZE);
const currentPage = 1;

const pageHref = (n: number) => (n === 1 ? `/community/${category}` : `/community/${category}/page/${n}`);
const nextHref = totalPages > 1 ? pageHref(2) : undefined;
---

<BaseLayout
  title={`${cat.label} · Community — CMK Image Korea`}
  description={`CMK ${cat.label} — ${cat.sanity}`}
>
  <CommunityPageHead active={cat.sanity} />

  <section class="bg-background">
    <div class="mx-auto max-w-[var(--container-max)] px-[var(--container-padding)] py-14 md:py-24">
      {posts.length === 0 ? (
        <div class="py-16 md:py-32 text-center">
          <p class="font-serif italic text-3xl text-faint">Coming Soon</p>
          <p class="mt-3 text-sm text-muted">아직 게시된 글이 없습니다.</p>
        </div>
      ) : (
        <>
          <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-2 md:gap-x-10 md:gap-y-20 lg:grid-cols-3">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            nextHref={nextHref}
            pageHref={pageHref}
          />
        </>
      )}
    </div>
  </section>

  <ScrollToTop />
</BaseLayout>
