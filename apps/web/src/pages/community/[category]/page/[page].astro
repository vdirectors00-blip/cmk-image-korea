---
// /community/[category]/page/[page] — 카테고리별 페이지 2 이상 (v1.3.16).
import BaseLayout from "@/layouts/BaseLayout.astro";
import CommunityPageHead from "@/components/community/CommunityPageHead.astro";
import PostCard from "@/components/community/PostCard.astro";
import Pagination from "@/components/community/Pagination.astro";
import ScrollToTop from "@/components/common/ScrollToTop.astro";

import { sanityClient } from "@/lib/sanity";
import { postsByCategoryQuery } from "@/lib/queries";
import type { Post, PostCategory } from "@/types/sanity";

export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const CATEGORY_MAP: Record<string, PostCategory> = {
    media: "강의·미디어",
    news: "뉴스",
  };

  const paths = [];
  for (const [slug, sanityCategory] of Object.entries(CATEGORY_MAP)) {
    const allPosts = await sanityClient.fetch<Post[]>(postsByCategoryQuery, { category: sanityCategory });
    const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
    for (let i = 2; i <= totalPages; i++) {
      paths.push({
        params: { category: slug, page: String(i) },
        props: {
          posts: allPosts.slice((i - 1) * PAGE_SIZE, i * PAGE_SIZE),
          currentPage: i,
          totalPages,
          sanityCategory,
        },
      });
    }
  }
  return paths;
}

const { category } = Astro.params;
const { posts, currentPage, totalPages, sanityCategory } = Astro.props as {
  posts: Post[];
  currentPage: number;
  totalPages: number;
  sanityCategory: PostCategory;
};

const LABEL_MAP: Record<string, string> = { media: "Media", news: "News" };
const label = LABEL_MAP[category as string] ?? "";

const pageHref = (n: number) => (n === 1 ? `/community/${category}` : `/community/${category}/page/${n}`);
const prevHref = pageHref(currentPage - 1);
const nextHref = currentPage < totalPages ? pageHref(currentPage + 1) : undefined;
---

<BaseLayout
  title={`${label} · Page ${currentPage} — CMK Image Korea`}
  description={`CMK ${label} — ${sanityCategory}`}
>
  <CommunityPageHead active={sanityCategory} />

  <section class="bg-background">
    <div class="mx-auto max-w-[var(--container-max)] px-[var(--container-padding)] py-24">
      <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-2 md:gap-x-10 md:gap-y-20 lg:grid-cols-3">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        prevHref={prevHref}
        nextHref={nextHref}
        pageHref={pageHref}
      />
    </div>
  </section>

  <ScrollToTop />
</BaseLayout>
