---
// /consulting/[slug] — service 상세 (정적 생성)
import BaseLayout from "@/layouts/BaseLayout.astro";
import ConsultingPageHead from "@/components/consulting/ConsultingPageHead.astro";
import PortableText from "@/components/common/PortableText.astro";
import ConsultingAxes from "@/components/consulting/ConsultingAxes.tsx";
import ScrollToTop from "@/components/common/ScrollToTop.astro";
import { sanityClient } from "@/lib/sanity";
import { serviceBySlugQuery, serviceSlugsQuery } from "@/lib/queries";
import { consultingAxesByCategory } from "@/lib/consulting-axes";
import { pickLocale } from "@/types/sanity";
import type { Service } from "@/types/sanity";

export async function getStaticPaths() {
  const slugs = await sanityClient.fetch<string[]>(serviceSlugsQuery);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const service = await sanityClient.fetch<Service | null>(serviceBySlugQuery, { slug });

if (!service) {
  return Astro.redirect("/consulting");
}

// v1.3.15 — 카드 컴포넌트가 있으면 PortableText body 대신 컴포넌트 노출.
// v1.3.16 — 상단 배너 이미지 제거 (인덱스 카드에만 노출).
const axesData = consultingAxesByCategory[service.category];
---

<BaseLayout
  title={`${pickLocale(service.title)} — Consulting · CMK Image Korea`}
  description={pickLocale(service.summary)}
>
  <ConsultingPageHead active={service.category} />

  <article class="bg-background">
    <div class="mx-auto max-w-[var(--container-max)] px-[var(--container-padding)] py-14 md:py-24">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">
        {service.category === "corporate" ? "Corporate"
          : service.category === "executive" ? "Executive PI"
          : service.category === "public" ? "Public · 기관·공공"
          : service.category === "media" ? "Media Training"
          : "Personal"}
      </p>
      <h2 class="mt-4 font-serif text-[clamp(40px,5vw,72px)] leading-[1.1] tracking-[-0.02em] text-foreground">
        {pickLocale(service.title)}
      </h2>
      {service.subtitle && (
        <p class="mt-4 font-serif italic text-2xl text-muted">
          {pickLocale(service.subtitle)}
        </p>
      )}

      {/* Summary intro */}
      {service.summary && (
        <p class="mt-12 max-w-4xl text-lg leading-[1.7] text-soft">
          {pickLocale(service.summary)}
        </p>
      )}

      {/* Body — 카드 컴포넌트 (v1.3.15) 또는 PortableText fallback (executive 등) */}
      {axesData ? (
        <div class="mt-20">
          <ConsultingAxes
            data={axesData}
            cardToggleLabel={service.category === "executive" || service.category === "personal" ? "세부 내용" : "진행 형식"}
            client:visible
          />
        </div>
      ) : service.body?.ko && service.body.ko.length > 0 && (
        <div class="mt-16 max-w-3xl space-y-4 [&_h2]:mt-14 [&_h2]:font-serif [&_h2]:text-3xl [&_h2]:tracking-[-0.01em] [&_h2]:text-foreground [&_h2:first-child]:mt-0 [&_h3]:mt-8 [&_h3]:font-serif [&_h3]:text-xl [&_h3]:text-foreground [&_p]:text-base [&_p]:leading-[1.85] [&_p]:text-soft [&_blockquote]:border-l-2 [&_blockquote]:border-accent [&_blockquote]:pl-6 [&_blockquote]:font-serif [&_blockquote]:italic [&_blockquote]:text-xl [&_blockquote]:text-foreground">
          <PortableText blocks={service.body.ko} />
        </div>
      )}

      {/* public 차별화 — 주요 사례 (audit §3-3, v1.3.15) */}
      {service.category === "public" && (
        <div class="mt-20 border-t border-foreground pt-12">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">
            Major Cases
          </p>
          <h3 class="mt-3 font-serif italic text-[clamp(28px,3.5vw,44px)] leading-tight tracking-[-0.01em] text-foreground">
            주요 사례
          </h3>
          <p class="mt-6 text-base leading-[1.7] text-soft break-keep">
            문화체육관광부 (2009·2012·2015) · 국무총리실 (2010) · 합동참모본부 (2012) · 국방부 국민소통 전문가단 (2024).
          </p>
        </div>
      )}

      {/* Highlights — v1.3.15 제거 (카드 contents 와 중복) */}

      <div class="mt-24 text-center">
        <a
          href={`/contact?form=${service.category === "corporate" ? "corporate" : "personal"}&service=${service.slug.current}`}
          class="inline-block border border-foreground px-8 py-4 text-sm uppercase tracking-[0.18em] text-foreground transition-[transform,background-color,color] duration-200 ease-[var(--ease-out-soft)] hover:-translate-y-[2px] hover:bg-foreground hover:text-on-dark"
        >
          {pickLocale(service.ctaText) || "이 컨설팅 문의 →"}
        </a>
      </div>
    </div>
  </article>

  <ScrollToTop />
</BaseLayout>
