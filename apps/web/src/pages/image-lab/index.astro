---
// /image-lab — 인덱스 (v1.3.15)
// 사용자 결정 — 3 영역 카드 클릭 시 그 분야 labArticle 노출.
import BaseLayout from "@/layouts/BaseLayout.astro";
import LabPageHead from "@/components/lab/LabPageHead.astro";
import LabAreasInteractive from "@/components/lab/LabAreasInteractive.tsx";
import ScrollToTop from "@/components/common/ScrollToTop.astro";

import { sanityClient } from "@/lib/sanity";
import { labArticlesAllQuery } from "@/lib/queries";
import type { LabArticle } from "@/types/sanity";

const articles = await sanityClient.fetch<LabArticle[]>(labArticlesAllQuery);
---

<BaseLayout
  title="Image Lab — CMK Image Korea"
  description="퍼스널컬러·스타일·골격·헤어 — CMK 이미지 연구 노트"
>
  <LabPageHead />

  <section class="bg-background">
    <div class="mx-auto max-w-[var(--container-max)] px-[var(--container-padding)] py-14 md:py-24">
      <LabAreasInteractive articles={articles} client:visible />
    </div>
  </section>

  <ScrollToTop />
</BaseLayout>
