function sNavAc(){
	$('.m_s_nav > div:eq(0) > ul li').eq(a_num).addClass('on');
	$('.m_s_nav > div:eq(1) > ul li').eq(b_num).addClass('on');
	$('.m_s_nav > div > a').on('click',function (e){
		e.stopPropagation();
		var t = $(this);
		if (t.next('ul').is(':hidden')) {
			t.next('ul').slideDown().parent().siblings().find('ul').slideUp();
		} else {
			t.next('ul').slideUp();
		}
	});
	$(document).on('click',function(e) {
		if ($(e.target).parents('.m_s_nav').length == 0) {
			$('.m_s_nav > div > a').next('ul').slideUp();
		}
	});
}